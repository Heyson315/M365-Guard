## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# ReSharper is a .NET coding add-in
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# NuGet Packages
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json

# Azure
*.pubxml
*.PublishSettings

# ===========================================
# 🔒 SECURITY: Never commit these files!
# ===========================================

# Secrets and sensitive configuration
appsettings.Production.json
appsettings.*.json
!appsettings.json
# SECURITY: Do NOT whitelist appsettings.Development.json - use dotnet user-secrets instead
secrets.json
*.pfx
*.p12
*.key
*.pem
*.cer
*.crt

# User secrets (should already be outside repo, but just in case)
**/secrets/
**/UserSecrets/

# Environment files
.env
.env.local
.env.*.local

# Excel files with potentially sensitive data
*.xlsm
*.xlsx
*.xls

# PowerShell credentials
*.credential
*.clixml

# Azure publish profiles
*.azurePubxml

# Certificate files
*.pfx
*.p12

# ===========================================
# END SECURITY SECTION
# ===========================================

# Windows image file caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Mac
.DS_Store

# JetBrains Rider
.idea/
*.sln.iml

# Node modules (if any)
node_modules/

# TypeScript
*.js.map

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.coverage
*.coveragexml

# Backup files
*.bak
*.backup
*~

# Temporary files
*.tmp
*.temp
*.log
